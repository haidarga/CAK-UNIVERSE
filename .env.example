# ============================================================
# CAK AI Ecosystem — Environment Variables
# Copy to .env.local and fill in. NEVER commit real secrets.
# ============================================================

# --- LLM provider selection ---
# Default provider for all agents: "anthropic" | "gemini"
# Each agent can also override this individually in code.
LLM_PROVIDER=anthropic

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-sonnet-4-6)
ANTHROPIC_MODEL=

# --- Google Gemini ---
GEMINI_API_KEY=
# Set the exact model id you have access to (e.g. gemini-2.5-flash / gemini-2.5-pro)
GEMINI_MODEL=gemini-2.5-flash

# --- Supabase ---
# Public (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# --- Telegram (anomaly alerts) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# --- TikTok scraping (RapidAPI) ---
RAPIDAPI_KEY=

# --- CAK AI Platform (video/slideshow generation) ---
CAKAI_PLATFORM_API_URL=
CAKAI_PLATFORM_API_KEY=

# --- Cron protection ---
# Random string; Vercel Cron sends this as Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# --- Dev integration: GitHub (dev_issues sync) ---
GITHUB_TOKEN=
GITHUB_REPO=                       # e.g. owner/repo

# --- Google Workspace (Docs / Sheets / Drive / YouTube / Analytics) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- YouTube Data API (trending for strategists — just an API key) ---
YOUTUBE_API_KEY=
YOUTUBE_REGION=ID

# --- Meta (Instagram) ---
META_APP_ID=
META_APP_SECRET=

# --- Social Growth Engineer (warmup automation) ---
SGE_API_URL=
SGE_API_KEY=

# --- Postiz (scheduling/publishing) ---
POSTIZ_API_URL=
POSTIZ_API_KEY=

# --- Lightpanda (headless browser for scraping + automation) ---
# CDP endpoint, e.g. ws://127.0.0.1:9222  (lightpanda serve)
LIGHTPANDA_CDP_URL=

# --- App ---
NEXT_PUBLIC_APP_NAME=CAK AI Ecosystem
