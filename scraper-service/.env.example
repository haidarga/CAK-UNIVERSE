# --- Shared secret with the Next app (set the same in Next .env.local SCRAPER_SERVICE_TOKEN) ---
SERVICE_TOKEN=

# --- TikTok (TikTok-Api) ---
# ms_token cookie from tiktok.com (DevTools → Application → Cookies → msToken)
MS_TOKEN=
TIKTOK_BROWSER=chromium

# --- Instagram (instagrapi) ---
# Prefer username + password (mobile API is more reliable than a browser sessionid)
IG_USERNAME=
IG_PASSWORD=
# Fallback only (browser cookie — often rejected by the mobile API):
IG_SESSIONID=
IG_SETTINGS=ig_session.json

# --- Proxy (recommended for TikTok at scale; residential works best) ---
# e.g. http://user:pass@host:port
PROXY=
